# ===========================================================================
# AI작당 환경 변수 예시 — 실제 값은 .env 에 작성한다(.env 는 커밋하지 않는다)
# 로컬 인프라: docker-compose.dev.yml (docs/adr/ADR-0001 참고)
# ===========================================================================

# --- 공통 ---
NODE_ENV=development

# --- 도메인 / URL (운영에서 실제 도메인으로 교체) ---
# 사용자 사이트(루트 도메인)
WEB_PUBLIC_URL=http://localhost:3003
# 관리자 사이트(admin 서브도메인)
ADMIN_PUBLIC_URL=http://localhost:3004
# API 서버(api 서브도메인)
API_PUBLIC_URL=http://localhost:4003

# 브라우저(Next.js)에서 호출할 API 주소
NEXT_PUBLIC_API_URL=http://localhost:4003

# --- 포트 ---
WEB_PORT=3003
ADMIN_PORT=3004
API_PORT=4003

# --- 데이터베이스 (PostgreSQL 17 + pg_bigm) ---
# 호스트 포트 5433 사용(기본 5432가 다른 스택과 충돌할 수 있어 회피). compose와 일치시킬 것.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/ai_jakdang

# --- Redis (캐시 / BullMQ / SSE Pub/Sub) — 호스트 6380 ---
REDIS_URL=redis://localhost:6380

# --- 인증 (Better Auth) ---
# 유저 신원과 관리자 신원은 완전 분리(ADR-0002 / ADR-0003): 시크릿/쿠키 별도.
AUTH_SECRET=change-me-to-a-long-random-string          # 유저 인증 인스턴스
ADMIN_AUTH_SECRET=change-me-to-another-long-random-string  # 관리자 인증 인스턴스(별도)
# 개발 전용 로그인 우회(가짜 로그인). production 에서는 반드시 false/제거.
AUTH_DEV_BYPASS=true

# --- 소셜 OAuth (유저 전용. 콜백: http://localhost:3003/api/v1/auth/callback/{provider} (웹 출처 프록시 — first-party 쿠키)) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# 카카오 이메일(account_email)은 비즈앱(사업자) 검수 후 제공됨(ADR-0002)
# 카카오 비즈앱 검수 완료 후 true 로 전환 (API 서버용)
KAKAO_ENABLED=false
# 카카오 로그인 버튼 활성 여부 (Next.js 클라이언트 노출용) — KAKAO_ENABLED 와 동기화
NEXT_PUBLIC_KAKAO_ENABLED=false
# 카카오톡 "공유하기" 버튼용 JavaScript 키 (로그인용 REST API 키와 별개, 앱 키 탭의 "JavaScript 키").
# 플랫폼 Web 사이트 도메인 등록 필요. 비우면 카카오 공유 버튼은 링크복사로 폴백.
NEXT_PUBLIC_KAKAO_JS_KEY=

# --- 파일 보안 스캔 (ClamAV / clamd) ---
CLAMD_HOST=localhost
CLAMD_PORT=3310

# --- S3 호환 스토리지 (로컬=MinIO / 운영=Cloudflare R2) ---
S3_ENDPOINT=http://localhost:9000        # 운영: https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin              # 운영: R2 access key
S3_SECRET_ACCESS_KEY=minioadmin          # 운영: R2 secret key
S3_FORCE_PATH_STYLE=true                 # MinIO 필요(R2도 호환)
S3_BUCKET_PUBLIC=ai-jakdang-public
S3_BUCKET_PRIVATE=ai-jakdang-private

# --- SMTP (이메일 발송) ---
# Gmail 사용 시: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
#   SMTP_USER=보내는Gmail주소, SMTP_PASSWORD=Google 앱 비밀번호(16자리, 일반 비번 아님)
#   앱 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
# 미설정 시 worker 가 콘솔에 인증/재설정 링크만 출력(개발 폴백).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# 공개 버킷 객체 외부 접근 베이스 URL(선택). 미설정 시 S3_ENDPOINT/S3_BUCKET_PUBLIC 로 구성.
# 운영(R2/CDN)에서는 커스텀 도메인을 넣는다.
S3_PUBLIC_BASE_URL=

# --- On-Demand Revalidation (Story 8.9) ---
# Next.js 캐시 즉시 무효화용 공유 시크릿.
# API 서버가 글 작성/수정/삭제 후 apps/web의 /api/revalidate 엔드포인트를 이 값으로 인증한다.
# 생성 예: node -e "console.log(require('crypto').randomUUID())"
REVALIDATE_SECRET=

# --- 최초 super_admin 시드 (Story 9.1) ---
# packages/database/src/seeds/super-admin.ts 실행 시 사용.
# 운영 배포 후 즉시 비밀번호를 변경할 것.
SUPER_ADMIN_EMAIL=superadmin@ai-jakdang.com
SUPER_ADMIN_NAME=최고관리자
SUPER_ADMIN_PHONE=010-0000-0000
SUPER_ADMIN_PASSWORD=ChangeMe123!

# ============================================================================
# 시딩 봇 (Seeding Bot) — docs/seeding-bot/DEPLOYMENT.md 참고
# 발급법은 DEPLOYMENT.md 각 절에. 키가 비면 해당 기능은 자동으로 건너뛴다(부분 가동 OK).
# 런타임 동작(킬스위치·속도·비용·관찰모드)은 env가 아니라 DB(bot_settings)에서 관리한다.
# ============================================================================

# --- AI 프로바이더 (봇 글·댓글·검열·이미지 생성). 셋 중 최소 1개 필요. 봇별 혼합 가능 ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- 검색 (글의 사실성 그라운딩) ---
# Brave Search API. Google Custom Search JSON API는 신규 고객 접근이 닫혀 있어 기본 검색 provider로 Brave를 사용한다.
BRAVE_SEARCH_API_KEY=
# Legacy Google Custom Search. 기존 접근 권한이 있는 오래된 프로젝트에서만 사용 가능.
GOOGLE_SEARCH_API_KEY=
# Programmable Search Engine ID(검색엔진 식별자)
GOOGLE_SEARCH_CX=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# --- 이미지 무료 스톡 (둘 중 하나 이상). AI 이미지 생성은 OPENAI_API_KEY 재사용 ---
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- 텔레그램 푸시 (일일 리포트 알림, 선택). @BotFather 발급 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 봇 부트스트랩 토글: 워커 부팅 시 봇 모듈 로드 여부(기본 false, 배포·시드·점검 후 true) ---
SEEDING_BOT_ENABLED=false

# --- 한국수출입은행 환율 API (관리자 달러 금액 원화 표기·매일 갱신) ---
# https://www.koreaexim.go.kr 오픈API에서 발급. 미설정 시 폴백 환율(달러당 1400원)로 표기.
KOREAEXIM_API_KEY=
