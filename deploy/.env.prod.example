# ===========================================================================
# AI작당 운영(.env) 예시 — 실제 값은 서버의 deploy/.env 에 채운다(커밋 금지).
# 시크릿(AUTH_SECRET/DB PW/MinIO 키)은 배포 스크립트가 강한 난수로 생성한다.
# 외부 API 키(OAuth/AI/검색/SMTP)는 로컬 .env 에서 그대로 옮긴다.
# ===========================================================================

NODE_ENV=production
AUTH_DEV_BYPASS=false

# ── 공개 URL / 포트 ──────────────────────────────────────────────────────
WEB_PUBLIC_URL=https://aijackdang.com
ADMIN_PUBLIC_URL=https://admin.aijackdang.com
API_PUBLIC_URL=https://api.aijackdang.com
NEXT_PUBLIC_API_URL=https://api.aijackdang.com
BETTER_AUTH_URL=https://api.aijackdang.com
COOKIE_DOMAIN=.aijackdang.com
API_INTERNAL_URL=http://api:4003
WEB_PORT=3003
ADMIN_PORT=3004
API_PORT=4003
API_HOST=0.0.0.0

# ── PostgreSQL (컨테이너 내부 네트워크) ──────────────────────────────────
POSTGRES_USER=aijakdang
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_DB=ai_jakdang
DATABASE_URL=postgres://aijakdang:__GENERATED__@postgres:5432/ai_jakdang

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── 인증 시크릿 (강한 난수로 생성) ───────────────────────────────────────
AUTH_SECRET=__GENERATED__
ADMIN_AUTH_SECRET=__GENERATED__

# ── ClamAV (업로드 스캔) ─────────────────────────────────────────────────
CLAMD_HOST=clamav
CLAMD_PORT=3310

# ── 오브젝트 스토리지 (MinIO) ────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=__GENERATED__
S3_SECRET_ACCESS_KEY=__GENERATED__
S3_FORCE_PATH_STYLE=true
S3_BUCKET_PUBLIC=ai-jakdang-public
S3_BUCKET_PRIVATE=ai-jakdang-private
S3_PUBLIC_BASE_URL=https://cdn.aijackdang.com

# ── 소셜 로그인 (로컬 .env 값 그대로) ────────────────────────────────────
#   OAuth 콜백 URL(각 개발자 콘솔에 등록 필요):
#     https://api.aijackdang.com/api/v1/auth/callback/google
#     https://api.aijackdang.com/api/v1/auth/callback/naver
#     https://api.aijackdang.com/api/v1/auth/callback/kakao
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ENABLED=true

# ── 메일(SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── 최고 관리자 (보존 대상) ──────────────────────────────────────────────
SUPER_ADMIN_EMAIL=aijackdang@gmail.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=최고관리자
SUPER_ADMIN_PHONE=010-2484-0289

# ── 시딩 봇 / AI (로컬 .env 값 그대로, 최초엔 비활성) ─────────────────────
SEEDING_BOT_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
