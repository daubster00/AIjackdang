{
  "name": "@ai-jakdang/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript / ESLint / Prettier 공통 설정 + env 단일 진입점 (비시각적 공유 코드)",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.node.json": "./tsconfig.node.json",
    "./tsconfig.react.json": "./tsconfig.react.json",
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "files": [
    "src",
    "tsconfig.base.json",
    "tsconfig.node.json",
    "tsconfig.react.json",
    "eslint.config.js",
    "prettier.config.js"
  ],
  "dependencies": {
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "eslint-plugin-react-hooks": "^7.1.1"
  }
}
